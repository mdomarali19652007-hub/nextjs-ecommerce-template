# ---------------------------------------------------------------------------
# Storefront environment. Copy to .env.local and fill in real values.
# ---------------------------------------------------------------------------

# Medusa backend URL. Default is the Medusa dev server hosted at /medusa.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key. Generate one in the Medusa admin under
# Settings > Publishable API Keys, attach it to a Sales Channel, and paste
# the pk_... value here.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_replace_me

# Default region handle. The seed script creates a Bangladesh region with
# currency BDT. Override per environment if you operate multi-region.
NEXT_PUBLIC_MEDUSA_DEFAULT_REGION=bd
