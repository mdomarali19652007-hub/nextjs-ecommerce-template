{
  "name": "nextjs-ecommerce-template-medusa",
  "version": "0.1.0",
  "description": "Medusa v2 backend for the Next.js ecommerce storefront. BDT region, hosted at /medusa in this repo.",
  "private": true,
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "build": "medusa build",
    "start": "medusa start",
    "dev": "medusa develop",
    "db:setup": "medusa db:create && medusa db:migrate",
    "db:migrate": "medusa db:migrate",
    "db:rollback": "medusa db:rollback",
    "db:reset": "medusa db:reset",
    "user": "medusa user",
    "seed": "medusa exec ./src/scripts/seed-storefront.ts"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "latest",
    "@medusajs/cli": "latest",
    "@medusajs/framework": "latest",
    "@medusajs/medusa": "latest",
    "@mikro-orm/core": "6.4.3",
    "@mikro-orm/knex": "6.4.3",
    "@mikro-orm/migrations": "6.4.3",
    "@mikro-orm/postgresql": "6.4.3",
    "awilix": "^8.0.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "latest",
    "@swc/core": "1.5.7",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11"
  },
  "engines": {
    "node": ">=20"
  }
}
