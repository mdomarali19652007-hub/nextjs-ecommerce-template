# ---------------------------------------------------------------------------
# Medusa backend env. Copy to .env and fill in real values.
# ---------------------------------------------------------------------------

# Postgres connection. Required.
# Example: postgres://medusa:medusa@localhost:5432/medusa_store
DATABASE_URL=postgres://postgres:postgres@localhost:5432/medusa_store

# Redis (event bus + cache). Optional in development; required in production.
REDIS_URL=redis://localhost:6379

# CORS — comma-separated origins. Add your prod storefront domain here.
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000,http://localhost:7001
AUTH_CORS=http://localhost:3000,http://localhost:9000,http://localhost:7001

# Secrets — rotate these in production.
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# Worker mode: shared | worker | server
MEDUSA_WORKER_MODE=shared

# Admin panel
MEDUSA_BACKEND_URL=http://localhost:9000
DISABLE_MEDUSA_ADMIN=false
